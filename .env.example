# .env.example — copy to .env and fill in your values.
# Every variable below is read by settings.py via python-decouple.

# --- Core ---
SECRET_KEY=your-django-secret-key-here
DEBUG=False
# Comma-separated. In production: yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=127.0.0.1,localhost

# --- Database (PostgreSQL) ---
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# --- Email (SMTP; for Gmail use an App Password) ---
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# --- Push notifications (VAPID) ---
# Generate your own keypair (see README). The PRIVATE key is a file:
# save it as private_key.pem in the project root — do NOT put it here.
VAPID_PUBLIC_KEY=
VAPID_ADMIN_EMAIL=your-email@example.com

# --- Site identity ---
SITE_NAME=
SITE_URL=http://127.0.0.1:8000

# --- Production only ---
# Comma-separated WITH scheme: https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=